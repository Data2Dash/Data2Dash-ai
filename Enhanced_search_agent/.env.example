
GROQ_API_KEY=your_groq_api_key_here
OPENALEX_MAILTO=your_email@example.com
SEMANTIC_SCHOLAR_API_KEY=
APP_NAME=DATA2DASH
APP_ENV=development
CHAT_MODEL=llama-3.3-70b-versatile
FAST_MODEL=llama-3.1-8b-instant
DEFAULT_PAGE_SIZE=25
MAX_RESULTS=0
ENABLE_OPENALEX_RETRIEVAL=true
ARXIV_PER_QUERY_CAP=100
OPENALEX_PER_QUERY_CAP=75
ARXIV_PER_QUERY_CAP_DEEP=100
OPENALEX_PER_QUERY_CAP_DEEP=100
RETRIEVAL_SOFT_CAP=1200
ENABLE_PROGRESSIVE_SOURCE_FETCH=true
ARXIV_PROGRESSIVE_MAX_TOTAL=400
OPENALEX_PROGRESSIVE_MAX_TOTAL=400
ARXIV_PROGRESSIVE_PAGE_SIZE=50
OPENALEX_PROGRESSIVE_PER_PAGE=200
ARXIV_PROGRESSIVE_MAX_PAGES=40
OPENALEX_PROGRESSIVE_MAX_PAGES=30
FAN_OUT_ALL_VARIANTS=false

ENABLE_RETRIEVAL_CS_CE_FIELD_FILTER=true
HYBRID_FILTER_MIN_SEMANTIC=0.06
HYBRID_FILTER_MIN_TOPIC=0.06
HYBRID_FILTER_KEEP_MIN=40
ARXIV_SEARCH_SORT_BY=relevance
ARXIV_DISK_CACHE_TTL_SECONDS=3600

ENABLE_SEMANTIC_RERANK=true
RERANK_BLEND=0.25
RERANK_POOL_SIZE=200

ENABLE_HYBRID_RERANK=false
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
HYBRID_RERANK_TOP_N=200
HYBRID_RERANK_BM25_WEIGHT=0.55
HYBRID_RERANK_EMBEDDING_WEIGHT=0.45
HYBRID_RERANK_COMPOSITE_BLEND=0.28
HYBRID_EMBEDDING_CACHE_MAX=2048

# Caches
DISK_CACHE_TTL_SECONDS=86400

# Legacy aggregate weights (see ranking_weights for learnable composite)
WEIGHT_RELEVANCE=0.65
WEIGHT_RECENCY=0.10
WEIGHT_CITATIONS=0.20
WEIGHT_SOURCE_CONFIDENCE=0.05

SOURCE_CONFIDENCE_ARXIV=0.85
SOURCE_CONFIDENCE_SEMANTIC_SCHOLAR=0.95
SOURCE_CONFIDENCE_OPENALEX=0.90
RANKING_WEIGHTS_JSON=
RANKING_WEIGHTS_FILE=

# Analytics
TREND_DAYS=30

ENABLE_RELEVANCE_FEEDBACK=true
